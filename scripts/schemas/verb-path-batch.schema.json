{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verb_id",
          "title",
          "meaning_zh",
          "scene",
          "schema_version",
          "root_action_id",
          "nodes",
          "links",
          "steps"
        ],
        "properties": {
          "verb_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "meaning_zh": {
            "type": "string",
            "minLength": 1
          },
          "scene": {
            "type": "string",
            "minLength": 1
          },
          "schema_version": {
            "type": "integer",
            "const": 2
          },
          "root_action_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "nodes": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "text", "kind", "label_zh"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "enum": ["action", "core", "modifier"]
                },
                "label_zh": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "links": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "from",
                "to",
                "kind",
                "relation_type",
                "label_zh"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "from": {
                  "type": "string",
                  "minLength": 1
                },
                "to": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "enum": ["core", "modifier"]
                },
                "relation_type": {
                  "type": "string",
                  "enum": [
                    "actor",
                    "target",
                    "recipient",
                    "content",
                    "nested_action",
                    "shared_actor",
                    "ownership",
                    "category",
                    "quality",
                    "frequency",
                    "time",
                    "place",
                    "condition",
                    "purpose",
                    "reason",
                    "manner",
                    "degree",
                    "scope",
                    "result",
                    "sequence"
                  ]
                },
                "label_zh": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 10,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_no",
                "label",
                "sentence_en",
                "sentence_zh",
                "add_node_ids",
                "add_link_ids",
                "focus_node_id",
                "note_zh"
              ],
              "properties": {
                "step_no": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "sentence_en": {
                  "type": "string",
                  "minLength": 1
                },
                "sentence_zh": {
                  "type": "string",
                  "minLength": 1
                },
                "add_node_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "add_link_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "focus_node_id": {
                  "type": "string",
                  "minLength": 1
                },
                "note_zh": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
